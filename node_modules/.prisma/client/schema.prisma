// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum DriverStatus {
  PENDING // En attente de validation
  APPROVED // Validé
  REJECTED // Rejeté
  SUSPENDED // Suspendu
}

enum DriverAvailability {
  ONLINE
  OFFLINE
  ON_RIDE
}

enum RideStatus {
  REQUESTED // Passager a demandé une course
  ACCEPTED // Chauffeur a accepté
  DRIVER_EN_ROUTE // Chauffeur en route vers passager
  ARRIVED // Chauffeur arrivé
  IN_PROGRESS // Course en cours
  COMPLETED // Course terminée
  CANCELLED // Annulée
}

enum PaymentMethod {
  CASH
  CARD
  ORANGE_MONEY
  FREE_MONEY
  WAVE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum VehicleType {
  BERLINE
  SUV
  VAN
  MOTO
  LUXE
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationType {
  RIDE_REQUEST
  RIDE_ACCEPTED
  RIDE_CANCELLED
  DRIVER_ARRIVED
  RIDE_COMPLETED
  PAYMENT_RECEIVED
  ACCOUNT_VALIDATED
  NEW_MESSAGE
  PROMO
}

// ─── Users ─────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  phone      String?  @unique
  firstName  String?
  lastName   String?
  avatarUrl  String?
  role       UserRole @default(PASSENGER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  language   String   @default("fr")
  fcmToken   String? // Firebase Cloud Messaging token
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Auth
  otpCode      String?
  otpExpiresAt DateTime?
  otpAttempts  Int       @default(0)
  refreshToken String?

  // Relations
  passengerRides  Ride[]         @relation("PassengerRides")
  sentMessages    Message[]      @relation("SentMessages")
  notifications   Notification[]
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  driver          Driver?
  payments        Payment[]

  @@map("users")
}

// ─── Drivers ───────────────────────────────────────────────────────────────

model Driver {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Infos véhicule
  vehicleType  VehicleType @default(BERLINE)
  vehicleMake  String? // Marque
  vehicleModel String? // Modèle
  vehicleYear  Int?
  vehiclePlate String?     @unique
  vehicleColor String?

  // Statut
  status       DriverStatus       @default(PENDING)
  availability DriverAvailability @default(OFFLINE)

  // Position GPS (mise à jour en temps réel)
  latitude       Float?
  longitude      Float?
  heading        Float? // Direction en degrés
  lastLocationAt DateTime?

  // Statistiques
  totalRides    Int   @default(0)
  totalEarnings Float @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  // Documents
  documents DriverDocument[]
  rides     Ride[]           @relation("DriverRides")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}

model DriverDocument {
  id         String   @id @default(uuid())
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type       String // 'license', 'id_card', 'insurance', 'registration', 'vtc_card'
  fileUrl    String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("driver_documents")
}

// ─── Rides ─────────────────────────────────────────────────────────────────

model Ride {
  id String @id @default(uuid())

  // Parties
  passengerId String
  passenger   User    @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId    String?
  driver      Driver? @relation("DriverRides", fields: [driverId], references: [id])

  // Lieux
  pickupAddress  String
  pickupLat      Float
  pickupLng      Float
  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  // Infos course
  status         RideStatus  @default(REQUESTED)
  vehicleType    VehicleType @default(BERLINE)
  estimatedPrice Float
  finalPrice     Float?
  distanceKm     Float?
  durationMin    Int?
  pinCode        String // Code PIN 4 chiffres pour démarrer

  // Paiement
  paymentMethod PaymentMethod @default(CASH)
  payment       Payment?

  // Timestamps des statuts
  requestedAt  DateTime  @default(now())
  acceptedAt   DateTime?
  arrivedAt    DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  // Relations
  messages Message[]
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rides")
}

// ─── Payments ──────────────────────────────────────────────────────────────

model Payment {
  id     String @id @default(uuid())
  rideId String @unique
  ride   Ride   @relation(fields: [rideId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount   Float
  currency String        @default("EUR")
  method   PaymentMethod
  status   PaymentStatus @default(PENDING)

  // Référence externe (Mobile Money, etc.)
  externalRef   String?
  failureReason String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("payments")
}

// ─── Messages (Chat in-app) ────────────────────────────────────────────────

model Message {
  id       String @id @default(uuid())
  rideId   String
  ride     Ride   @relation(fields: [rideId], references: [id], onDelete: Cascade)
  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  content String
  type    MessageType @default(TEXT)
  isRead  Boolean     @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@map("messages")
}

// ─── Reviews ───────────────────────────────────────────────────────────────

model Review {
  id       String @id @default(uuid())
  rideId   String
  ride     Ride   @relation(fields: [rideId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("ReviewsGiven", fields: [authorId], references: [id])
  targetId String
  target   User   @relation("ReviewsReceived", fields: [targetId], references: [id])

  rating  Int // 1-5
  comment String?

  createdAt DateTime @default(now())

  @@unique([rideId, authorId])
  @@map("reviews")
}

// ─── Notifications ─────────────────────────────────────────────────────────

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   NotificationType
  title  String
  body   String
  data   Json? // Données supplémentaires (rideId, etc.)
  isRead Boolean          @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@map("notifications")
}
